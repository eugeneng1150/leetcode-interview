{
  "manifest_version": 3,
  "name": "LeetCode Interviewer Mode",
  "version": "0.1.1",
  "description": "Adds interview-style practice flows to LeetCode problem pages.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://leetcode.com/problems/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LeetCode Interviewer Mode",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  }
}
