{
  "manifest_version": 3,
  "name": "LeetCode Interviewer Mode",
  "version": "0.1.0",
  "description": "Adds interview-style practice flows to LeetCode problem pages.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://leetcode.com/problems/*"
  ],
  "background": {
    "service_worker": "dist/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "dist/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "LeetCode Interviewer Mode"
  }
}
